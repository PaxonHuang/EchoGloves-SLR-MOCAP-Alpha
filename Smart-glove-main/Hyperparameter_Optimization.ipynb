    "random_time = time.time() - start_time\n",
    "\n",
    "print(f\"\\n搜索完成！耗时: {random_time:.2f}秒\")\n",
    "print(f\"\\n最佳参数:\")\n",
    "for param, value in random_search.best_params_.items():\n",
    "    print(f\"  {param}: {value}\")\n",
    "print(f\"\\n最佳交叉验证准确率: {random_search.best_score_:.4f}\")\n",
    "\n",
    "# 测试集评估\n",
    "random_best_model = random_search.best_estimator_\n",
    "random_test_acc = random_best_model.score(X_test, y_test)\n",
    "print(f\"测试集准确率: {random_test_acc:.4f}\")\n",
    "\n",
    "# 对比\n",
    "print(f\"\\n📊 对比:\")\n",
    "print(f\"  网格搜索: {grid_time:.2f}秒, 准确率: {grid_test_acc:.4f}\")\n",
    "print(f\"  随机搜索: {random_time:.2f}秒, 准确率: {random_test_acc:.4f}\")\n",
    "print(f\"  速度提升: {grid_time/random_time:.2f}倍\")"
   ]
