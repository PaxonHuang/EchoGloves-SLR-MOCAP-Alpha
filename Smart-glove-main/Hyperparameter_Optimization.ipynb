  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 网格搜索\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"🔍 网格搜索 (Grid Search)\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# 定义参数网格\n",
    "param_grid = {\n",
    "    'n_estimators': [100, 200, 500],\n",
    "    'max_depth': [5, 10, 15],\n",
    "    'min_samples_split': [2, 5, 10],\n",
    "    'min_samples_leaf': [1, 2, 4]\n",
    "}\n",
    "\n",
    "# 计算搜索空间大小\n",
    "search_space_size = np.prod([len(v) for v in param_grid.values()])\n",
    "print(f\"参数组合数: {search_space_size}\")\n",
    "\n",
    "# 创建GridSearchCV\n",
    "grid_search = GridSearchCV(\n",
    "    RandomForestClassifier(random_state=42, n_jobs=-1),\n",
    "    param_grid,\n",
    "    cv=3,\n",
    "    scoring='accuracy',\n",
    "    n_jobs=-1,\n",
    "    verbose=1\n",
    ")\n",
    "\n",
    "# 执行搜索\n",
    "start_time = time.time()\n",
    "grid_search.fit(X_train, y_train)\n",
    "grid_time = time.time() - start_time\n",
    "\n",
    "print(f\"\\n搜索完成！耗时: {grid_time:.2f}秒\")\n",
    "print(f\"\\n最佳参数:\")\n",
    "for param, value in grid_search.best_params_.items():\n",
    "    print(f\"  {param}: {value}\")\n",
    "print(f\"\\n最佳交叉验证准确率: {grid_search.best_score_:.4f}\")\n",
    "\n",
    "# 测试集评估\n",
    "grid_best_model = grid_search.best_estimator_\n",
    "grid_test_acc = grid_best_model.score(X_test, y_test)\n",
    "print(f\"测试集准确率: {grid_test_acc:.4f}\")"
   ]
