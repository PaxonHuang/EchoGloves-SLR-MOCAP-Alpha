    "    # 测试集评估\n",
    "    bayes_best_model = bayes_search.best_estimator_\n",
    "    bayes_test_acc = bayes_best_model.score(X_test, y_test)\n",
    "    print(f\"测试集准确率: {bayes_test_acc:.4f}\")\n",
    "else:\n",
    "    print(\"\\n⚠️ scikit-optimize未安装，跳过贝叶斯优化\")"
