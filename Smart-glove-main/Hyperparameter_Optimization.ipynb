    "## 第二步：数据加载"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 加载数据\n",
    "GESTURE_CLASSES = [\n",
    "    'a', 'b', 'c', 'd', 'e', 'f', 'g', 'h', 'i', 'j', 'k', 'l', 'm',\n",
    "    'bad', 'deaf', 'fine', 'good', 'hello', 'hungry', 'me', 'no', 'please'\n",
    "]\n",
    "\n",
    "def load_data(data_path, gesture_classes, sample_per_class=1000):\n",
    "    \"\"\"加载数据（子采样加速优化）\"\"\"\n",
    "    all_data = []\n",
    "    \n",
    "    for gesture in gesture_classes:\n",
    "        file_path = os.path.join(data_path, f'{gesture}_merged.csv_exported.csv')\n",
    "        if os.path.exists(file_path):\n",
    "            df = pd.read_csv(file_path)\n",
",
    "            feature_cols = ['flex_1', 'flex_2', 'flex_3', 'flex_4', 'flex_5',\n",
    "                          'GYRx', 'GYRy', 'GYRz', 'ACCx', 'ACCy', 'ACCz']\n",
    "            df = df[['Alphabet'] + feature_cols].dropna()\n",
    "            df[feature_cols[:5]] = df[feature_cols[:5]].clip(lower=0)\n",
    "            \n",
    "            # 子采样\n",
    "            if len(df) > sample_per_class:\n",
    "                df = df.sample(n=sample_per_class, random_state=42)\n",
    "            \n",
    "            all_data.append(df)\n",
    "    \n",
    "    combined_df = pd.concat(all_data, ignore_index=True)\n",
    "    \n",
    "    # 特征工程\n",
    "    X = combined_df[feature_cols].values\n",
    "    y = combined_df['Alphabet'].values\n",
    "    \n",
    "    # 归一化\n",
    "    flex_max = X[:, :5].max()\n",
    "    X[:, :5] = X[:, :5] / flex_max if flex_max > 0 else X[:, :5]\n",
    "    X[:, 5:8] = X[:, 5:8] / 9.81\n",
    "    gyro_max = np.abs(X[:, 8:11]).max()\n",
    "    X[:, 8:11] = X[:, 8:11] / gyro_max if gyro_max > 0 else X[:, 8:11]\n",
    "    \n",
    "    le = LabelEncoder()\n",
    "    y = le.fit_transform(y)\n",
    "    \n",
    "    return X, y\n",
    "\n",
    "# 加载（使用子采样加速）\n",
    "X, y = load_data('modified dataset/alphabet/', GESTURE_CLASSES, sample_per_class=500)\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)\n",
    "\n",
    "print(f\"训练集: {X_train.shape[0]}\")\n",
    "print(f\"测试集: {X_test.shape[0]}\")\n",
    "print(f\"类别数: {len(np.unique(y))}\")"
   ]
  },
