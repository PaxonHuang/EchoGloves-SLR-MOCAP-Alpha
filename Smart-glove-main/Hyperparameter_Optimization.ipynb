   "source": [
    "## 第六步：粒子群优化 (PSO)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# PSO实现\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"🐦 粒子群优化 (Particle Swarm Optimization)\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "class PSOOptimizer:\n",
    "    \"\"\"\n",
    "    粒子群优化器\n",
    "    \n",
    "    公式:\n",
    "    v_i(t+1) = w*v_i(t) + c1*r1*(pbest_i - x_i) + c2*r2*(gbest - x_i)\n",
    "    x_i(t+1) = x_i(t) + v_i(t+1)\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, n_particles=20, n_iterations=30, w=0.7, c1=1.5, c2=1.5):\n",
    "        self.n_particles = n_particles\n",
    "        self.n_iterations = n_iterations\n",
    "        self.w = w  # 惯性权重\n",
    "        self.c1 = c1  # 认知系数\n",
    "        self.c2 = c2  # 社会系数\n",
    "        \n",
    "    def optimize(self, X_train, y_train, param_bounds):\n",
    "        \"\"\"执行PSO优化\"\"\"\n",
    "        \n",
    "        # 初始化粒子\n",
    "        n_params = len(param_bounds)\n",
    "        particles = np.random.rand(self.n_particles, n_params)\n",
    "        velocities = np.zeros((self.n_particles, n_params))\n",
    "        \n",
    "        # 将粒子映射到参数空间\n",
    "        def decode_particle(particle):\n",
    "            params = {}\n",
    "            for i, (param_name, (low, high)) in enumerate(param_bounds.items()):\n",
    "                params[param_name] = int(low + particle[i] * (high - low))\n",
    "            return params\n",
    "        \n",
    "        # 评估适应度\n",
    "        def evaluate(params):\n",
    "            model = RandomForestClassifier(\n",
    "                **params,\n",
    "                random_state=42,\n",
    "                n_jobs=-1\n",
    "            )\n",
    "            scores = cross_val_score(model, X_train, y_train, cv=3, scoring='accuracy')\n",
    "            return scores.mean()\n",
    "        \n",
    "        # 初始化pbest和gbest\n",
    "        pbest_positions = particles.copy()\n",
    "        pbest_scores = [evaluate(decode_particle(p)) for p in particles]\n",
    "        gbest_idx = np.argmax(pbest_scores)\n",
    "        gbest_position = particles[gbest_idx].copy()\n",
    "        gbest_score = pbest_scores[gbest_idx]\n",
    "        \n",
    "        # 优化历史\n",
    "        history = [gbest_score]\n",
    "        \n",
    "        # 迭代优化\n",
    "        for iteration in range(self.n_iterations):\n",
    "            for i in range(self.n_particles):\n",
    "                # 更新速度\n",
    "                r1, r2 = np.random.rand(2)\n",
    "                velocities[i] = (\n",
    "                    self.w * velocities[i] +\n",
    "                    self.c1 * r1 * (pbest_positions[i] - particles[i]) +\n",
    "                    self.c2 * r2 * (gbest_position - particles[i])\n",
    "                )\n",
    "                \n",
    "                # 更新位置\n",
    "                particles[i] += velocities[i]\n",
    "                particles[i] = np.clip(particles[i], 0, 1)  # 限制在[0,1]\n",
    "                \n",
    "                # 评估新位置\n",
    "                score = evaluate(decode_particle(particles[i]))\n",
    "                \n",
    "                # 更新pbest\n",
    "                if score > pbest_scores[i]:\n",
    "                    pbest_scores[i] = score\n",
    "                    pbest_positions[i] = particles[i].copy()\n",
    "                    \n",
    "                    # 更新gbest\n",
    "                    if score > gbest_score:\n",
    "                        gbest_score = score\n",
    "                        gbest_position = particles[i].copy()\n",
    "            \n",
    "            history.append(gbest_score)\n",
    "            \n",
    "            if (iteration + 1) % 5 == 0:\n",
    "                print(f\"迭代 {iteration+1}/{self.n_iterations}, 最佳准确率: {gbest_score:.4f}\")\n",
    "        \n",
    "        return decode_particle(gbest_position), gbest_score, history\n",
    "\n",
    "# 定义参数边界\n",
    "param_bounds = {\n",
    "    'n_estimators': (100, 1000),\n",
    "    'max_depth': (3, 20),\n",
    "    'min_samples_split': (2, 20),\n",
    "    'min_samples_leaf': (1, 10)\n",
    "}\n",
    "\n",
    "# 执行PSO\n",
    "pso = PSOOptimizer(n_particles=15, n_iterations=20)\n",
    "start_time = time.time()\n",
    "pso_best_params, pso_best_score, pso_history = pso.optimize(X_train, y_train, param_bounds)\n",
    "pso_time = time.time() - start_time\n",
    "\n",
    "print(f\"\\nPSO优化完成！耗时: {pso_time:.2f}秒\")\n",
    "print(f\"\\n最佳参数:\")\n",
    "for param, value in pso_best_params.items():\n",
    "    print(f\"  {param}: {value}\")\n",
    "print(f\"\\n最佳交叉验证准确率: {pso_best_score:.4f}\")\n",
    "\n",
    "# 训练最终模型\n",
    "pso_best_model = RandomForestClassifier(\n",
    "    **pso_best_params,\n",
    "    random_state=42,\n",
    "    n_jobs=-1\n",
    ")\n",
    "pso_best_model.fit(X_train, y_train)\n",
    "pso_test_acc = pso_best_model.score(X_test, y_test)\n",
    "print(f\"测试集准确率: {pso_test_acc:.4f}\")"
   ]
